POSTGRES_PASSWORD=changeme
POSTGRES_DB=life_logger
POSTGRES_USER=life_logger
DATABASE_URL=postgresql+asyncpg://life_logger:changeme@postgres:5432/life_logger
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── 관리자 API 토큰 (소스 코드에 기본값 없음 — 반드시 설정) ──
# Docker Compose 실행 전 이 파일을 .env 로 복사하고, 아래 두 값을 동일한 임의 비밀 문자열로 바꾸세요.
# 예: openssl rand -hex 32
#
# API_ADMIN_TOKEN          → 백엔드: 비-GET /api/v1 요청의 Authorization: Bearer 검사
# NEXT_PUBLIC_API_ADMIN_TOKEN → 프론트 Docker 빌드 시 주입(브라우저 번들에 포함됨). 관리자 로그인 UI에서
#                               입력값이 이 값과 일치할 때만 세션에 저장(힌트 모드).
#                               비워 두고 빌드하면 번들에 토큰 힌트가 없고, 사용자가 서버 토큰을 직접 입력.
# 로컬에서만 쓸 값 예: hde-system (`.env`에만 두고 Git에는 올리지 말 것)
API_ADMIN_TOKEN=
NEXT_PUBLIC_API_ADMIN_TOKEN=

# Docker Compose: frontend OpenClaw 마운트(기본 ~/.openclaw). 틸드가 안 되면 절대 경로로 지정
# OPENCLAW_HOST_PATH=/Users/you/.openclaw
