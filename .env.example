POSTGRES_PASSWORD=changeme
POSTGRES_DB=life_logger
POSTGRES_USER=life_logger
DATABASE_URL=postgresql+asyncpg://life_logger:changeme@postgres:5432/life_logger
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# 백엔드: 비-GET /api/v1 요청에 필요 (기본 hde-system)
API_ADMIN_TOKEN=hde-system
# 프론트(브라우저): POST/PUT/PATCH/DELETE 시 Authorization 헤더로 전달 (로컬·Docker에서 백엔드와 동일 값 권장)
NEXT_PUBLIC_API_ADMIN_TOKEN=hde-system

# Docker Compose: frontend OpenClaw 마운트(기본 ~/.openclaw). 틸드가 안 되면 절대 경로로 지정
# OPENCLAW_HOST_PATH=/Users/you/.openclaw
